            "example": "joao@email.com"
          },
          "perfil": {
            "type": "string",
            "enum": [
              "Administrador",
              "Supervisor",
              "Padr?o"
            ],
            "example": "Administrador"
          },
          "status": {
            "type": "string",
            "enum": [
              "Ativo",
              "Inativo"
            ],
            "example": "Ativo"
          },
