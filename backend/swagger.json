{
  "openapi": "3.0.0",
  "info": {
    "title": "AutoPro API",
    "description": "Documentacao das rotas da API AutoPro baseada na modelagem Cliente, Veiculo, Servico, Item de Servico e Produto.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Servidor local"
    }
  ],
  "tags": [
    {
      "name": "Clientes",
      "description": "Operacoes relacionadas aos clientes"
    },
    {
      "name": "Veiculos",
      "description": "Operacoes relacionadas aos veiculos"
    },
    {
      "name": "Servicos",
      "description": "Operacoes relacionadas aos servicos"
    },
    {
      "name": "Itens de Servico",
      "description": "Operacoes relacionadas aos produtos utilizados em servicos"
    },
    {
      "name": "Produtos",
      "description": "Operacoes relacionadas ao estoque de produtos"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Verifica se a API esta rodando",
        "tags": ["Status"],
        "responses": {
          "200": {
            "description": "API em execucao",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiMessage"
                },
                "example": {
                  "message": "API AutoPro rodando"
                }
              }
            }
          }
        }
      }
    },
    "/clientes": {
      "get": {
        "summary": "Lista todos os clientes",
        "tags": ["Clientes"],
        "responses": {
          "200": {
            "description": "Lista de clientes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Cliente"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Cria um cliente",
        "tags": ["Clientes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClienteInput"
              },
              "example": {
                "nome": "Maria Silva",
                "email": "maria@email.com",
                "telefone": "(11) 99999-9999"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Cliente criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cliente"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/clientes/{id}": {
      "get": {
        "summary": "Busca um cliente por ID",
        "tags": ["Clientes"],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          }
        ],
        "responses": {
          "200": {
            "description": "Cliente encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cliente"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "summary": "Atualiza um cliente",
        "tags": ["Clientes"],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClienteInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cliente atualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cliente"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "summary": "Remove um cliente",
        "tags": ["Clientes"],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          }
        ],
        "responses": {
          "204": {
            "description": "Cliente removido"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/veiculos": {
      "get": {
        "summary": "Lista todos os veiculos",
