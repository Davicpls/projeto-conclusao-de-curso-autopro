        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VeiculoInput"
              },
              "example": {
                "placa": "ABC1D23",
                "marca": "Toyota",
                "modelo": "Corolla",
                "ano": 2020,
                "id_cliente": 1
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Veiculo criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Veiculo"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
