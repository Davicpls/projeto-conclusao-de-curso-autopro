          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProdutoInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Produto atualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Produto"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "summary": "Remove um produto",
        "tags": ["Produtos"],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          }
        ],
        "responses": {
          "204": {
            "description": "Produto removido"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Id": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "ID do registro",
        "schema": {
          "type": "integer",
          "example": 1
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Dados invalidos ou obrigatorios ausentes",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiMessage"
            }
          }
        }
      },
      "NotFound": {
        "description": "Registro nao encontrado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiMessage"
            }
          }
        }
      },
      "Conflict": {
        "description": "Operacao bloqueada por relacionamento ou regra de negocio",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiMessage"
            }
          }
        }
      }
    },
    "schemas": {
      "ApiMessage": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Mensagem da API"
          }
        }
      },
      "Cliente": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 1
              }
            }
          },
          {
            "$ref": "#/components/schemas/ClienteInput"
          }
        ]
      },
      "ClienteInput": {
        "type": "object",
        "required": ["nome", "email", "telefone"],
        "properties": {
          "nome": {
            "type": "string",
            "example": "Maria Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "maria@email.com"
          },
          "telefone": {
            "type": "string",
            "example": "(11) 99999-9999"
          }
        }
      },
      "Veiculo": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 1
              }
            }
          },
          {
            "$ref": "#/components/schemas/VeiculoInput"
          }
        ]
      },
      "VeiculoInput": {
        "type": "object",
        "required": ["placa", "marca", "modelo", "ano", "id_cliente"],
        "properties": {
          "placa": {
            "type": "string",
            "example": "ABC1D23"
          },
          "marca": {
            "type": "string",
            "example": "Toyota"
          },
          "modelo": {
            "type": "string",
            "example": "Corolla"
          },
          "ano": {
            "type": "integer",
            "example": 2020
          },
          "id_cliente": {
            "type": "integer",
            "example": 1
          }
        }
      },
      "Servico": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 1
              }
            }
          },
          {
            "$ref": "#/components/schemas/ServicoInput"
          }
        ]
      },
      "ServicoInput": {
        "type": "object",
        "required": [
          "descricao",
          "status",
          "data_inicio",
          "valor_total",
          "id_veiculo"
        ],
        "properties": {
          "descricao": {
            "type": "string",
            "example": "Troca de oleo"
          },
          "status": {
            "type": "string",
            "example": "em andamento"
          },
          "data_inicio": {
            "type": "string",
            "format": "date",
            "example": "2026-05-01"
          },
          "data_fim": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "example": "2026-05-02"
          },
          "valor_total": {
            "type": "number",
            "format": "float",
            "example": 250
          },
          "id_veiculo": {
            "type": "integer",
            "example": 1
          }
        }
      },
      "ItemServico": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 1
              }
            }
          },
          {
            "$ref": "#/components/schemas/ItemServicoInput"
          }
        ]
      },
      "ItemServicoInput": {
        "type": "object",
        "required": ["id_servico", "id_produto", "quantidade_utilizada"],
        "properties": {
          "id_servico": {
            "type": "integer",
            "example": 1
          },
          "id_produto": {
            "type": "integer",
            "example": 1
          },
          "quantidade_utilizada": {
            "type": "number",
            "format": "float",
            "example": 2
          }
        }
      },
      "Produto": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 1
              }
            }
          },
          {
            "$ref": "#/components/schemas/ProdutoInput"
          }
        ]
      },
      "ProdutoInput": {
        "type": "object",
        "required": ["nome", "quantidade", "preco_unitario"],
        "properties": {
          "nome": {
            "type": "string",
            "example": "Oleo 5W30"
          },
          "quantidade": {
            "type": "number",
            "format": "float",
            "example": 12
          },
          "preco_unitario": {
            "type": "number",
            "format": "float",
            "example": 65.5
          }
        }
      }
    }
  }
}
