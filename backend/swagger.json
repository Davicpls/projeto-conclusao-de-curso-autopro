    "/itens-servico": {
      "get": {
        "summary": "Lista todos os itens de servico",
        "tags": ["Itens de Servico"],
        "responses": {
          "200": {
            "description": "Lista de itens de servico",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ItemServico"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Cria um item de servico",
        "tags": ["Itens de Servico"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ItemServicoInput"
              },
              "example": {
                "id_servico": 1,
                "id_produto": 1,
                "quantidade_utilizada": 2
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Item de servico criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemServico"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/itens-servico/{id}": {
      "get": {
        "summary": "Busca um item de servico por ID",
