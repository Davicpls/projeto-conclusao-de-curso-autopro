          "id_servico": {
            "type": "integer",
            "example": 1
          },
          "id_produto": {
            "type": "integer",
            "example": 1
          },
          "quantidade_utilizada": {
            "type": "number",
            "format": "float",
            "example": 2
          }
        }
      },
      "Produto": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 1
              }
            }
          },
          {
            "$ref": "#/components/schemas/ProdutoInput"
          }
        ]
