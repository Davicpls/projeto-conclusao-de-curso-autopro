                "type": "string",
                "format": "date-time",
                "example": "2026-05-03T14:23:20.266Z"
              },
              "data_atualizacao": {
                "type": "string",
                "format": "date-time",
                "example": "2026-05-03T14:23:20.266Z"
              }
            }
          },
          {
            "$ref": "#/components/schemas/VeiculoInput"
          }
        ]
      },
