        "type": "object",
        "required": [
          "placa",
          "modelo",
          "ano",
          "cor",
          "id_cliente"
        ],
        "properties": {
          "placa": {
            "type": "string",
            "example": "ABC1D23"
          },
          "modelo": {
            "type": "string",
            "example": "Corolla"
          },
          "ano": {
            "type": "integer",
            "example": 2020
          },
          "cor": {
            "type": "string",
            "example": "Prata"
          },
          "quilometragem": {
            "type": "integer",
            "example": 45000,
            "default": 0
          },
          "tipoVeiculo": {
            "type": "string",
            "nullable": true,
            "example": "Sedan"
          },
          "motorizacao": {
            "type": "string",
            "nullable": true,
            "example": "2.0 Flex"
          },
          "numeroChasse": {
            "type": "string",
            "nullable": true,
            "example": "9BWZZZ377VT004251"
          },
          "tipoCombustivel": {
            "type": "string",
            "nullable": true,
            "example": "Flex"
          },
          "dataUltimaRevisao": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "example": "2026-04-20"
          },
          "id_cliente": {
            "type": "integer",
            "example": 1
          }
        }
      },
      "Servico": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 1
              }
            }
          },
          {
            "$ref": "#/components/schemas/ServicoInput"
          }
        ]
      },
      "ServicoInput": {
        "type": "object",
        "required": [
          "descricao",
          "status",
          "data_inicio",
          "valor_total",
          "id_veiculo"
        ],
        "properties": {
          "descricao": {
            "type": "string",
            "example": "Troca de oleo"
          },
          "status": {
            "type": "string",
            "example": "em andamento"
          },
          "data_inicio": {
            "type": "string",
            "format": "date",
            "example": "2026-05-01"
          },
          "data_fim": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "example": "2026-05-02"
          },
          "valor_total": {
            "type": "number",
            "format": "float",
            "example": 250
          },
          "id_veiculo": {
            "type": "integer",
            "example": 1
          }
        }
