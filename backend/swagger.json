        "properties": {
          "nome": {
            "type": "string",
            "example": "Maria Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "maria@email.com"
          },
          "telefone": {
            "type": "string",
            "example": "(11) 99999-9999"
          }
        }
      },
      "Veiculo": {
        "allOf": [
          {
            "type": "object",
