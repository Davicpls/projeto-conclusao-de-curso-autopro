            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ItemServicoInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item de servico atualizado",
            "content": {
              "application/json": {
                "schema": {
